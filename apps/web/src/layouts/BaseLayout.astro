---
import { ClientRouter } from 'astro:transitions'

interface Props {
  title?: string
  description?: string
}

const {
  title = '個人園地',
  description = '動態留下當下，文章留下價值。'
} = Astro.props
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <ClientRouter />
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans TC', sans-serif;
        line-height: 1.8;
        color: #1d1d1f;
        background: #fcfbf8;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
        display: inline-block;
      }
      .btn-primary {
        background: #0066cc;
        color: white;
      }
      .btn-primary:hover {
        background: #0052a3;
      }
      .btn-secondary {
        background: #f0f0f0;
        color: #000;
        border: 1px solid #ddd;
      }
      .btn-secondary:hover {
        background: #e0e0e0;
      }
    </style>
  </head>
  <body>
    <nav class="navbar" id="navbar">
      <a href="/" class="logo">Double River</a>
      <div class="nav-links">
        <a href="/stream">動態</a>
        <a href="/articles">文章</a>
      </div>
      <button class="menu-toggle" id="menuToggle" aria-label="開啟選單">
        <span class="menu-icon"></span>
      </button>
    </nav>

    <!-- 側邊選單 -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-close" id="sidebarClose" aria-label="關閉選單">&times;</button>
      <nav class="sidebar-nav">
        <a href="/">首頁</a>
        <a href="/stream">動態</a>
        <a href="/articles">文章</a>
        <hr />
        <a href="/c/journal">日記</a>
        <a href="/c/reading">讀書</a>
        <a href="/c/travel">旅行</a>
        <a href="/c/place">地點</a>
      </nav>
    </aside>

    <main class="main-content">
      <slot />
    </main>
    <footer>
      <p>&copy; 2024-2026 雙河道</p>
    </footer>

    <script>
      function initNavigation() {
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const closeBtn = document.getElementById('sidebarClose');

        function openSidebar() {
          sidebar?.classList.add('open');
          overlay?.classList.add('open');
          document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
          sidebar?.classList.remove('open');
          overlay?.classList.remove('open');
          document.body.style.overflow = '';
        }

        menuToggle?.addEventListener('click', openSidebar);
        overlay?.addEventListener('click', closeSidebar);
        closeBtn?.addEventListener('click', closeSidebar);

        // 點連結後自動關閉
        sidebar?.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', closeSidebar);
        });

        // 標記目前頁面
        const currentPath = window.location.pathname;
        sidebar?.querySelectorAll('a').forEach(link => {
          const href = link.getAttribute('href');
          if (href === currentPath || (href !== '/' && currentPath.startsWith(href!))) {
            link.classList.add('active');
          }
        });

        // 頂部導覽滾動隱藏/顯示
        let lastScrollY = 0;
        let isHiding = false;
        const navbar = document.getElementById('navbar');

        document.addEventListener('scroll', () => {
          const currentScrollY = window.scrollY;
          if (currentScrollY > lastScrollY && currentScrollY > 100) {
            if (!isHiding) {
              navbar?.classList.add('hide');
              isHiding = true;
            }
          } else if (currentScrollY < lastScrollY) {
            if (isHiding) {
              navbar?.classList.remove('hide');
              isHiding = false;
            }
          }
          lastScrollY = currentScrollY;
        }, { passive: true });
      }

      initNavigation();
      document.addEventListener('astro:after-swap', initNavigation);
    </script>

    <style>
      /* ===== 頂部導覽 ===== */
      .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 2rem;
        border-bottom: 1px solid #e8e2d9;
        background: #fcfbf8;
        position: sticky;
        top: 0;
        z-index: 100;
        transition: transform 0.3s ease-out;
      }

      .navbar.hide {
        transform: translateY(-100%);
      }

      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
        font-size: 0.95rem;
      }

      .nav-links a {
        color: #6b6b73;
        transition: color 0.2s;
      }

      .nav-links a:hover {
        color: #1d1d1f;
      }

      /* 漢堡選單按鈕 — 手機才顯示 */
      .menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        -webkit-tap-highlight-color: transparent;
      }

      .menu-icon,
      .menu-icon::before,
      .menu-icon::after {
        display: block;
        width: 20px;
        height: 2px;
        background: #1d1d1f;
        border-radius: 1px;
        transition: all 0.2s;
      }

      .menu-icon {
        position: relative;
      }

      .menu-icon::before,
      .menu-icon::after {
        content: '';
        position: absolute;
        left: 0;
      }

      .menu-icon::before {
        top: -6px;
      }

      .menu-icon::after {
        top: 6px;
      }

      /* ===== 側邊選單 ===== */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.3);
        z-index: 200;
        opacity: 0;
        transition: opacity 0.3s;
      }

      .sidebar-overlay.open {
        display: block;
        opacity: 1;
      }

      .sidebar {
        position: fixed;
        top: 0;
        right: 0;
        width: 280px;
        max-width: 80vw;
        height: 100dvh;
        background: #fcfbf8;
        z-index: 201;
        transform: translateX(100%);
        transition: transform 0.3s ease-out;
        padding: 2rem 1.5rem;
        overflow-y: auto;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .sidebar-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        font-size: 1.75rem;
        cursor: pointer;
        color: #999;
        line-height: 1;
        padding: 4px 8px;
      }

      .sidebar-close:hover {
        color: #333;
      }

      .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin-top: 2.5rem;
      }

      .sidebar-nav a {
        display: block;
        padding: 0.85rem 0;
        font-size: 1.05rem;
        color: #444;
        border-bottom: 1px solid #f0ece4;
        transition: color 0.2s;
      }

      .sidebar-nav a:hover {
        color: #0066cc;
      }

      .sidebar-nav a.active {
        color: #0066cc;
        font-weight: 600;
      }

      .sidebar-nav hr {
        border: none;
        border-top: 1px solid #e8e2d9;
        margin: 0.5rem 0;
      }

      /* ===== 主內容 ===== */
      .main-content {
        max-width: 820px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        min-height: 70vh;
      }

      footer {
        text-align: center;
        padding: 2rem;
        color: #999;
        border-top: 1px solid #e8e2d9;
        margin-top: 4rem;
        font-size: 0.9rem;
      }

      /* ===== 手機版 ===== */
      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .menu-toggle {
          display: block;
        }

        .navbar {
          padding: 1rem 1.25rem;
        }

        .main-content {
          padding: 1.25rem 1rem;
        }
      }

      @media (min-width: 769px) {
        .sidebar,
        .sidebar-overlay {
          display: none !important;
        }
      }
    </style>
  </body>
</html>
