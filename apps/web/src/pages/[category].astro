---
import BaseLayout from '../layouts/BaseLayout.astro'
import EntryCard from '../components/EntryCard.astro'
import { getEntriesByCategory } from '../lib/data'
import { buildEntryCardModels, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from '../lib/presenters'
import { applyPageCacheHeaders } from '../lib/response'

export async function getStaticPaths() {
  const categories = ['journal', 'reading', 'travel', 'place']
  return categories.map((category) => ({
    params: { category },
  }))
}

const { category } = Astro.params
const label = CATEGORY_LABELS[category || ''] || category || ''
const description = CATEGORY_DESCRIPTIONS[category || ''] || ''

let cardModels: Awaited<ReturnType<typeof buildEntryCardModels>> = []
let error: string | null = null

try {
  const entries = await getEntriesByCategory(category || '')
  cardModels = await buildEntryCardModels(entries, {
    categoryLabelOverride: label,
    excerptLength: 120,
  })
} catch (e) {
  error = '無法載入內容，請稍後重試'
}

applyPageCacheHeaders(Astro.response, 'articles')
---

<BaseLayout title={`${label} | Double River`} description={description}>
  <div class="category-container">
    <header class="category-header">
      <h1>{label}</h1>
      {description && <p class="category-desc">{description}</p>}
    </header>

    {error && <div class="error-message">{error}</div>}

    <div class="entries-list">
      {
        cardModels.length > 0 ? (
          cardModels.map((vm) => (
            <EntryCard
              href={vm.href}
              title={vm.displayTitle}
              excerpt={vm.displayExcerpt}
              date={vm.displayDate}
              categoryLabel={vm.categoryLabel}
              typeLabel={vm.typeLabel}
              coverUrl={vm.coverUrl}
              coverAlt={vm.coverAlt}
              stats={vm.metrics}
              variant="list"
              showTypeBadge={true}
            />
          ))
        ) : (
          <p class="empty-state">這個分類還沒有內容</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .category-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .category-header {
    margin-bottom: 2.5rem;
  }

  .category-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .category-desc {
    color: #888;
    font-size: 0.95rem;
  }

  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .error-message {
    background: #fee;
    color: #c00;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 2rem;
  }

  @media (max-width: 640px) {
    .category-container {
      padding: 1.25rem 1rem;
    }

    .category-header h1 {
      font-size: 1.3rem;
    }
  }
</style>
