---
import BaseLayout from '../layouts/BaseLayout.astro'
import EntryCard from '../components/EntryCard.astro'
import SystemNoticeCard from '../components/SystemNoticeCard.astro'
import { getPosts, getArticles } from '../lib/data'
import { buildEntryCardModels } from '../lib/presenters'
import { buildUnifiedFeed, isSystemNotice } from '../lib/feed'
import { applyPageCacheHeaders } from '../lib/response'

const [allPosts, allArticles] = await Promise.all([
  getPosts(),
  getArticles(),
])

const [postModels, articleModels] = await Promise.all([
  buildEntryCardModels(allPosts, { excerptLength: 100 }),
  buildEntryCardModels(allArticles, { excerptLength: 120 }),
])

const dayGroups = buildUnifiedFeed(postModels, articleModels)

applyPageCacheHeaders(Astro.response, 'stream')
---

<BaseLayout title="動態 | Double River" description="像社群河道一樣，收納當下的片段。">
  <div class="stream-container">
    <header class="stream-header">
      <h1>動態</h1>
      <p>日常短記、書摘、旅途感想</p>
    </header>

    <div class="timeline">
      {
        dayGroups.length > 0 ? (
          dayGroups.map((group) => (
            <section class="day-group">
              <div class="day-label">
                <span>{group.displayDate}</span>
              </div>

              <div class="day-items">
                {group.items.map((item) =>
                  isSystemNotice(item) ? (
                    <SystemNoticeCard message={item.message} href={item.href} />
                  ) : (
                    <EntryCard
                      href={item.href}
                      title={item.displayTitle}
                      excerpt={item.displayExcerpt}
                      date={item.displayDate}
                      categoryLabel={item.categoryLabel}
                      coverUrl={item.coverUrl}
                      coverAlt={item.coverAlt}
                      stats={item.metrics}
                      variant="compact"
                    />
                  )
                )}
              </div>
            </section>
          ))
        ) : (
          <p class="empty-state">還沒有任何貼文</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .stream-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .stream-header {
    margin-bottom: 2.5rem;
  }

  .stream-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .stream-header p {
    color: #888;
    font-size: 0.95rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .day-group {
    margin-bottom: 0.5rem;
  }

  .day-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: #888;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .day-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e0d8;
  }

  .day-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 3rem;
  }

  @media (max-width: 640px) {
    .stream-container {
      padding: 1.25rem 1rem;
    }

    .stream-header h1 {
      font-size: 1.3rem;
    }
  }
</style>
