---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPosts } from '../lib/data'
import { formatDate } from '@personal-blog/shared'
import { extractPlainText } from '../lib/markdown'
import { applyPageCacheHeaders } from '../lib/response'

const categoryLabels: Record<string, string> = {
  journal: '日記',
  reading: '讀書',
  travel: '旅行',
  place: '地點',
}

// SSR: 每次請求時取最新資料
const posts = await getPosts()

const displayPosts = posts.map((post) => ({
  ...post,
  displayTitle: post.title?.trim() || formatDate(post.created_at),
  displayExcerpt: extractPlainText(post.content_markdown || '', 100),
  categoryLabel: categoryLabels[post.category] || post.category,
}))

const groupedPosts = displayPosts.reduce((acc, post) => {
  const dateKey = post.created_at.slice(0, 10)
  if (!acc[dateKey]) acc[dateKey] = []
  acc[dateKey].push(post)
  return acc
}, {} as Record<string, typeof displayPosts>)

const groupedEntries = Object.entries(groupedPosts).sort(([a], [b]) =>
  a < b ? 1 : -1
)

// 應用快取策略：30秒 CDN 快取 + 2 分鐘過期後仍可用
applyPageCacheHeaders(Astro.response, 'stream')
---

<BaseLayout title="動態 | Double River" description="像社群河道一樣，收納當下的片段。">
  <div class="stream-container">
    <header class="stream-header">
      <h1>動態</h1>
      <p>日常短記、書摘、旅途感想</p>
    </header>

    <div class="timeline">
      {
        groupedEntries.length > 0 ? (
          groupedEntries.map(([date, items]) => (
            <section class="day-group">
              <div class="day-label">
                <span>{formatDate(date)}</span>
              </div>

              <div class="day-items">
                {items.map((post) => (
                  <a class="timeline-item" href={`/post/${encodeURIComponent(post.slug || '')}`}>
                    <div class="item-body">
                      <h2 class="item-title">{post.displayTitle}</h2>
                      {post.displayExcerpt && post.displayExcerpt !== post.displayTitle && (
                        <p class="item-excerpt">{post.displayExcerpt}</p>
                      )}
                    </div>
                    <span class="item-category">{post.categoryLabel}</span>
                  </a>
                ))}
              </div>
            </section>
          ))
        ) : (
          <p class="empty-state">還沒有任何貼文</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .stream-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .stream-header {
    margin-bottom: 2.5rem;
  }

  .stream-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .stream-header p {
    color: #888;
    font-size: 0.95rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .day-group {
    margin-bottom: 0.5rem;
  }

  .day-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: #888;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .day-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e0d8;
  }

  .day-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid #f0ece4;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .timeline-item:hover {
    background: #faf8f5;
    margin: 0 -0.75rem;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    border-radius: 6px;
  }

  .timeline-item:last-child {
    border-bottom: none;
  }

  .item-body {
    flex: 1;
    min-width: 0;
  }

  .item-title {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .item-excerpt {
    margin: 0.3rem 0 0;
    font-size: 0.88rem;
    color: #777;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .item-category {
    flex-shrink: 0;
    font-size: 0.8rem;
    color: #999;
    margin-top: 0.15rem;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 3rem;
  }

  @media (max-width: 640px) {
    .stream-container {
      padding: 1.25rem 1rem;
    }

    .stream-header h1 {
      font-size: 1.3rem;
    }

    .item-title {
      font-size: 0.95rem;
    }
  }
</style>
