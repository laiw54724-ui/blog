---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ReaderControls from '../../components/ReaderControls.astro'
import { formatDate } from '@personal-blog/shared'
import { renderMarkdownToHtml, stripFirstH1, extractH1Title } from '../../lib/markdown'
import { getEntryBySlug, getAssetsByEntryId } from '../../lib/data'
import { applyPageCacheHeaders } from '../../lib/response'

const slug = Astro.params.slug
const entry = slug ? await getEntryBySlug(decodeURIComponent(slug)) : null

if (!entry) {
  return Astro.redirect('/stream')
}

// Strip the first H1 before rendering — it's shown separately as the page <title>
// (but for posts, we don't show a duplicate h1 header)
const titleFromEntry = entry.title?.replace(/^#+\s+/, '').trim()
const titleFromContent = titleFromEntry ? null : extractH1Title(entry.content_markdown || '')
const displayTitle = titleFromEntry || titleFromContent || formatDate(entry.created_at)
const cleanedMarkdown = titleFromEntry || titleFromContent ? stripFirstH1(entry.content_markdown || '') : entry.content_markdown || ''
const renderedContent = await renderMarkdownToHtml(cleanedMarkdown)

const assets = await getAssetsByEntryId(entry.id)
const API_BASE = (import.meta as any).env.PUBLIC_API_URL || 'https://personal-blog-api.personal-blog.workers.dev'

// Build image list: cover first (if set), then extras
const coverAsset = assets.find((a: any) => a.kind === 'cover')
const imageAssets = assets.filter((a: any) => a.kind === 'image')
const allImages: any[] = [
  ...(coverAsset ? [coverAsset] : []),
  ...imageAssets,
]

const visibleImages = allImages.slice(0, 4)
const extraCount = allImages.length - visibleImages.length
const imageCount = Math.min(allImages.length, 4)

applyPageCacheHeaders(Astro.response, 'detail')
---

<BaseLayout title={`${displayTitle} | Double River`}>
  <ReaderControls client:load />
  <article class="post">

    <!-- Top bar: date + category -->
    <div class="post-meta">
      <time datetime={entry.created_at}>{formatDate(entry.created_at)}</time>
      {entry.category && (
        <a href={`/c/${entry.category}`} class="category-tag">{entry.category}</a>
      )}
    </div>

    <!-- Post body: content text + images -->
    <div class="post-body">

      <header class="post-title-wrapper">
        <h1 class="post-title">{displayTitle}</h1>
      </header>

      <div class="post-text markdown-content" id="postText" set:html={renderedContent} />

      <!-- Image gallery (FB-style) -->
      {allImages.length > 0 && (
        <div class="image-gallery" data-count={imageCount}>
          {visibleImages.map((asset: any, i: number) => (
            <button
              class="gallery-item"
              data-src={`${API_BASE}/api/assets/${asset.storage_key}`}
              data-alt={asset.alt_text || displayTitle}
              aria-label={`查看圖片 ${i + 1}`}
            >
              <img
                src={`${API_BASE}/api/assets/${asset.storage_key}`}
                alt={asset.alt_text || ''}
                loading={i === 0 ? 'eager' : 'lazy'}
                width={asset.width || undefined}
                height={asset.height || undefined}
              />
              {i === 3 && extraCount > 0 && (
                <span class="gallery-more" aria-hidden="true">+{extraCount}</span>
              )}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Footer nav -->
    <footer class="post-footer">
      <a href="/stream" class="btn-back">← 返回動態</a>
      {entry.category && (
        <a href={`/c/${entry.category}`} class="btn-category">#{entry.category}</a>
      )}
    </footer>
  </article>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" hidden>
    <div class="lightbox-overlay" id="lightboxOverlay"></div>
    <button class="lightbox-close" id="lightboxClose" aria-label="關閉">✕</button>
    <img class="lightbox-img" id="lightboxImg" src="" alt="" />
  </div>
</BaseLayout>

<style>
  article.post {
    max-width: 680px;
    margin: 0 auto;
    padding: 1.25rem 0 2rem;
  }

  /* ── Meta bar ── */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: #999;
  }

  .category-tag {
    color: #0066cc;
    text-decoration: none;
    font-size: 0.82rem;
  }

  .category-tag:hover {
    text-decoration: underline;
  }

  .post-title-wrapper {
    padding: 0 1.25rem;
    margin-bottom: 0.75rem;
  }

  .post-title {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.2;
    font-weight: 700;
    color: #212121;
  }

  /* ── Body ── */
  .post-body {
    background: #fff;
    border: 1px solid #ece7df;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }

  /* ── Text content ── */
  .post-text {
    padding: 1.25rem 1.25rem 1rem;
    font-size: 1em; /* inherits from article so ReaderControls works */
    line-height: 1.85;
    color: #333;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ── Markdown typography ── */
  .markdown-content p {
    margin-bottom: 1em;
  }

  .markdown-content p:last-child {
    margin-bottom: 0;
  }

  .markdown-content h1,
  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4,
  .markdown-content h5,
  .markdown-content h6 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-weight: 600;
    line-height: 1.4;
    color: #1a1a1a;
    position: relative;
  }

  .markdown-content h1 { font-size: 1.4em; }
  .markdown-content h2 { font-size: 1.25em; }
  .markdown-content h3 { font-size: 1.1em; }

  .markdown-content .heading-anchor {
    color: #666;
    text-decoration: none;
    margin-left: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .markdown-content h1:hover .heading-anchor,
  .markdown-content h2:hover .heading-anchor,
  .markdown-content h3:hover .heading-anchor,
  .markdown-content h4:hover .heading-anchor,
  .markdown-content h5:hover .heading-anchor,
  .markdown-content h6:hover .heading-anchor {
    opacity: 1;
  }

  .markdown-content ul,
  .markdown-content ol {
    margin: 0.75em 0;
    padding-left: 1.4rem;
    list-style-position: outside;
  }

  .markdown-content ul {
    list-style-type: disc;
  }

  .markdown-content ol {
    list-style-type: decimal;
  }

  .markdown-content li {
    margin-bottom: 0.45em;
    line-height: 1.75;
  }

  .markdown-content li > p {
    margin-bottom: 0.3em;
  }

  .markdown-content blockquote {
    border-left: 3px solid #ddd;
    padding-left: 1rem;
    margin: 1em 0;
    color: #666;
    background: #fafafa;
    padding: 0.75rem 1rem;
    border-radius: 4px;
  }

  .markdown-content code {
    background: #f4f4f4;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
    font-size: 0.88em;
  }

  .markdown-content pre {
    background: #f8f8f8;
    border-left: 3px solid #e0dbd3;
    padding: 0.85rem 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1em 0;
  }

  .markdown-content pre code {
    background: none;
    padding: 0;
    font-size: 0.9em;
  }

  .markdown-content a {
    color: #0066cc;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .markdown-content a:hover {
    text-decoration-style: solid;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 1em 0;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e8e2d9;
    margin: 2rem 0;
  }

  /* Tables */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0;
    font-size: 0.9em;
  }

  .markdown-content th,
  .markdown-content td {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .markdown-content th {
    background: #f8f8f8;
    font-weight: 600;
  }

  .markdown-content tr:nth-child(even) {
    background: #fafafa;
  }

  /* Task lists */
  .markdown-content input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  /* Footnotes */
  .markdown-content .footnotes {
    border-top: 1px solid #e8e2d9;
    margin-top: 2rem;
    padding-top: 1rem;
    font-size: 0.9em;
  }

  .markdown-content .footnotes ol {
    margin: 0;
    padding-left: 1.5rem;
  }

  .markdown-content .footnotes li {
    margin-bottom: 0.5rem;
  }

  /* KaTeX styles */
  .katex {
    font-size: 1.1em;
  }

  .katex-display {
    margin: 1rem 0;
    text-align: center;
  }

  /* Highlight.js styles (GitHub theme) */
  .hljs {
    background: #f6f8fa;
    color: #24292f;
  }

  .hljs-keyword,
  .hljs-selector-tag,
  .hljs-literal,
  .hljs-section,
  .hljs-link {
    color: #d73a49;
  }

  .hljs-built_in,
  .hljs-type {
    color: #6f42c1;
  }

  .hljs-number,
  .hljs-attr,
  .hljs-subst {
    color: #005cc5;
  }

  .hljs-string,
  .hljs-title,
  .hljs-name,
  .hljs-tag .hljs-attr {
    color: #032f62;
  }

  .hljs-symbol,
  .hljs-bullet,
  .hljs-addition {
    color: #22863a;
  }

  .hljs-code,
  .hljs-formula {
    background: #f6f8fa;
  }

  .hljs-comment,
  .hljs-quote {
    color: #6a737d;
  }

  .hljs-meta,
  .hljs-deletion {
    color: #b31d28;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e8e2d9;
    margin: 1.5em 0;
  }

  /* ── Image Gallery (FB-style) ── */
  .image-gallery {
    display: grid;
    gap: 3px;
    background: #000;
    /* max-height so portrait images don't go crazy tall */
  }

  /* 1 image: full width */
  .image-gallery[data-count="1"] {
    grid-template-columns: 1fr;
  }
  .image-gallery[data-count="1"] .gallery-item {
    aspect-ratio: 16 / 9;
  }

  /* 2 images: side by side */
  .image-gallery[data-count="2"] {
    grid-template-columns: 1fr 1fr;
  }
  .image-gallery[data-count="2"] .gallery-item {
    aspect-ratio: 1 / 1;
  }

  /* 3 images: large left + 2 stacked right */
  .image-gallery[data-count="3"] {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .image-gallery[data-count="3"] .gallery-item:first-child {
    grid-row: span 2;
    aspect-ratio: auto;
  }
  .image-gallery[data-count="3"] .gallery-item:not(:first-child) {
    aspect-ratio: 16 / 9;
  }

  /* 4 images: 2x2 */
  .image-gallery[data-count="4"] {
    grid-template-columns: 1fr 1fr;
  }
  .image-gallery[data-count="4"] .gallery-item {
    aspect-ratio: 1 / 1;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border: none;
    padding: 0;
    background: #111;
    display: block;
    width: 100%;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-more {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1.75rem;
    font-weight: 700;
    pointer-events: none;
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    cursor: pointer;
  }

  .lightbox-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    position: relative;
    z-index: 1;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  /* ── Footer ── */
  .post-footer {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-back,
  .btn-category {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.88rem;
    transition: all 0.15s;
  }

  .btn-back {
    background: #f0f0f0;
    color: #444;
  }

  .btn-back:hover { background: #e0e0e0; }

  .btn-category {
    color: #0066cc;
    background: #eef5ff;
  }

  .btn-category:hover { background: #deeaff; }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    article.post {
      padding: 0.75rem 0 1.5rem;
    }

    .post-text {
      padding: 1rem 1rem 0.75rem;
    }
  }
</style>

<script>
  // ── Lightbox ──────────────────────────────────────────────────────────────
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;
  const lightboxOverlay = document.getElementById('lightboxOverlay');
  const lightboxClose = document.getElementById('lightboxClose');

  document.querySelectorAll<HTMLButtonElement>('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      const src = item.dataset.src;
      const alt = item.dataset.alt || '';
      if (lightbox && lightboxImg && src) {
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightbox.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeLightbox() {
    lightbox?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  lightboxOverlay?.addEventListener('click', closeLightbox);
  lightboxClose?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
