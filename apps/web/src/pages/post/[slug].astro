---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ReaderControls from '../../components/ReaderControls.astro'
import CommentBoard from '../../components/CommentBoard.astro'
import 'katex/dist/katex.min.css'
import { formatDate } from '@personal-blog/shared'
import { renderMarkdownToHtml, stripFirstH1, extractH1Title } from '../../lib/markdown'
import { getEntryBySlug, getAssetsByEntryId, getEntryMetrics, getEntryComments } from '../../lib/data'
import { applyPageCacheHeaders } from '../../lib/response'

const slug = Astro.params.slug
const entry = slug ? await getEntryBySlug(decodeURIComponent(slug)) : null

if (!entry) {
  return Astro.redirect('/stream')
}

// Strip the first H1 before rendering — it's shown separately as the page <title>
// (but for posts, we don't show a duplicate h1 header)
const titleFromEntry = entry.title?.replace(/^#+\s+/, '').trim()
const titleFromContent = titleFromEntry ? null : extractH1Title(entry.content_markdown || '')
const displayTitle = titleFromEntry || titleFromContent || formatDate(entry.created_at)
const cleanedMarkdown = titleFromEntry || titleFromContent ? stripFirstH1(entry.content_markdown || '') : entry.content_markdown || ''
const renderedContent = await renderMarkdownToHtml(cleanedMarkdown)

const assets = await getAssetsByEntryId(entry.id)
const API_BASE = (import.meta as any).env.PUBLIC_API_URL || 'https://personal-blog-api.personal-blog.workers.dev'

// Fetch metrics and comments via service binding
const [metrics, initialComments] = await Promise.all([
  getEntryMetrics(entry.id),
  getEntryComments(entry.id),
])

// Build image list: cover first (if set), then extras
const coverAsset = assets.find((a: any) => a.kind === 'cover')
const imageAssets = assets.filter((a: any) => a.kind === 'image')
const allImages: any[] = [
  ...(coverAsset ? [coverAsset] : []),
  ...imageAssets,
]

const visibleImages = allImages.slice(0, 4)
const extraCount = allImages.length - visibleImages.length
const imageCount = Math.min(allImages.length, 4)

applyPageCacheHeaders(Astro.response, 'detail')
---

<BaseLayout title={`${displayTitle} | Double River`}>
  <ReaderControls client:load />
  <article class="post">

    <!-- Back nav -->
    <div class="post-nav">
      <a href="/stream" class="btn-back">← 返回動態</a>
    </div>

    <!-- Top bar: date + category -->
    <div class="post-meta">
      <time datetime={entry.created_at}>{formatDate(entry.created_at)}</time>
      {entry.category && (
        <a href={`/c/${entry.category}`} class="category-tag">{entry.category}</a>
      )}
    </div>

    <!-- Post body: content text + images -->
    <div class="post-body">

      <header class="post-title-wrapper">
        <h1 class="post-title">{displayTitle}</h1>
      </header>

      <div class="post-text markdown-content" id="postText" set:html={renderedContent} />

      <!-- Image gallery (FB-style) -->
      {allImages.length > 0 && (
        <div class="image-gallery" data-count={imageCount}>
          {visibleImages.map((asset: any, i: number) => (
            <button
              class="gallery-item"
              data-src={`${API_BASE}/api/assets/${asset.storage_key}`}
              data-alt={asset.alt_text || displayTitle}
              aria-label={`查看圖片 ${i + 1}`}
            >
              <img
                src={`${API_BASE}/api/assets/${asset.storage_key}`}
                alt={asset.alt_text || ''}
                loading={i === 0 ? 'eager' : 'lazy'}
                width={asset.width || undefined}
                height={asset.height || undefined}
              />
              {i === 3 && extraCount > 0 && (
                <span class="gallery-more" aria-hidden="true">+{extraCount}</span>
              )}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Engagement bar -->
    <div class="post-engagement">
      <button
        class="engage-btn clap-btn"
        id="clapBtn"
        data-entry-id={entry.id}
        data-api-base={API_BASE}
        aria-label="拍手"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span id="clapCount">{metrics.clap_count}</span>
      </button>

      <a href="#comments" class="engage-btn" aria-label="留言">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <span data-metric="comments">{metrics.comment_count}</span>
      </a>

      <span class="engage-stat" aria-label="閱讀數">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        <span id="viewCount">{metrics.view_count}</span>
      </span>
    </div>

  </article>

  <!-- Comments -->
  <div id="comments" class="post-comments">
    <CommentBoard
      entryId={entry.id}
      initialComments={initialComments}
      apiBase={API_BASE}
    />
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" hidden>
    <div class="lightbox-overlay" id="lightboxOverlay"></div>
    <button class="lightbox-close" id="lightboxClose" aria-label="關閉">✕</button>
    <img class="lightbox-img" id="lightboxImg" src="" alt="" />
  </div>
</BaseLayout>

<script is:inline>
  function initCodeCopy(root = document) {
    root.querySelectorAll('.markdown-content pre').forEach((pre) => {
      if (!(pre instanceof HTMLElement) || pre.dataset.copyBound === '1') return;
      pre.dataset.copyBound = '1';

      const code = pre.querySelector('code');
      if (!(code instanceof HTMLElement)) return;

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'code-copy-btn';
      button.textContent = '複製';

      button.addEventListener('click', async () => {
        const text = code.innerText;
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = '已複製';
          window.setTimeout(() => {
            button.textContent = '複製';
          }, 1400);
        } catch {
          button.textContent = '失敗';
          window.setTimeout(() => {
            button.textContent = '複製';
          }, 1400);
        }
      });

      pre.appendChild(button);
    });
  }

  initCodeCopy();
  document.addEventListener('astro:after-swap', () => initCodeCopy());
</script>

<style is:global>
  article.post {
    max-width: 680px;
    margin: 0 auto;
    padding: 1rem 0 1.35rem;
  }

  /* ── Meta bar ── */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
    color: #999;
  }

  .category-tag {
    color: var(--accent, #5b74c8);
    text-decoration: none;
    font-size: 0.82rem;
  }

  .category-tag:hover {
    text-decoration: underline;
  }

  .post-title-wrapper {
    padding: 1.1rem 1.1rem 0.8rem;
    border-bottom: 1px solid var(--border, #dddaf0);
  }

  .post-title {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.25;
    font-weight: 700;
    color: #212121;
  }

  /* ── Body ── */
  .post-body {
    background: #fff;
    border: 1px solid #ece7df;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  /* ── Text content ── */
  .post-text {
    padding: 1rem 1.1rem 0.95rem;
    font-size: 1rem;
    line-height: 1.75;
    color: #333;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ── Markdown typography ── */
  .markdown-content p {
    margin-bottom: 1em;
  }

  .markdown-content p:last-child {
    margin-bottom: 0;
  }

  .markdown-content h1,
  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4,
  .markdown-content h5,
  .markdown-content h6 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-weight: 600;
    line-height: 1.4;
    color: #1a1a1a;
    position: relative;
  }

  .markdown-content h1 { font-size: 1.4em; }
  .markdown-content h2 { font-size: 1.25em; }
  .markdown-content h3 { font-size: 1.1em; }

  .markdown-content .heading-anchor {
    color: #666;
    text-decoration: none;
    margin-left: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .markdown-content h1:hover .heading-anchor,
  .markdown-content h2:hover .heading-anchor,
  .markdown-content h3:hover .heading-anchor,
  .markdown-content h4:hover .heading-anchor,
  .markdown-content h5:hover .heading-anchor,
  .markdown-content h6:hover .heading-anchor {
    opacity: 1;
  }

  .markdown-content figure.md-figure {
    margin: 1.2rem 0;
  }

  .markdown-content figure.md-figure img {
    margin: 0;
  }

  .markdown-content figcaption.md-figcaption {
    margin-top: 0.5rem;
    font-size: 0.86rem;
    line-height: 1.55;
    color: #7f7b92;
    text-align: center;
  }

  .markdown-content ul,
  .markdown-content ol {
    margin: 0.85rem 0 0.85rem 0.15rem;
    padding-left: 1.45rem;
    list-style-position: outside;
  }

  .markdown-content ul {
    list-style-type: disc;
  }

  .markdown-content ol {
    list-style-type: decimal;
  }

  .markdown-content li {
    margin-bottom: 0.45em;
    line-height: 1.75;
  }

  .markdown-content li > ul,
  .markdown-content li > ol {
    margin-top: 0.45rem;
    margin-bottom: 0.55rem;
  }

  .markdown-content li > p {
    margin-bottom: 0.3em;
  }

  .markdown-content blockquote {
    border-left: 4px solid #a8b8e0;
    padding: 0.6rem 1rem 0.6rem 1.1rem;
    margin: 1rem 0;
    color: #555;
    background: #f3f5fb;
    border-radius: 0 6px 6px 0;
    font-style: normal;
  }

  .markdown-content blockquote > :first-child {
    margin-top: 0;
  }

  .markdown-content blockquote > :last-child {
    margin-bottom: 0;
  }

  .markdown-content blockquote ol,
  .markdown-content blockquote ul {
    margin-left: 0.1rem;
  }

  .markdown-content .callout {
    border-left-width: 5px;
    border-left-style: solid;
    padding: 0.8rem 1rem 0.85rem 1.05rem;
  }

  .markdown-content .callout-title {
    font-size: 0.77rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }

  .markdown-content .callout-note {
    border-left-color: #7d8fdc;
    background: #f5f7ff;
  }

  .markdown-content .callout-note .callout-title {
    color: #5369c6;
  }

  .markdown-content .callout-tip {
    border-left-color: #5eaf8b;
    background: #f2fbf6;
  }

  .markdown-content .callout-tip .callout-title {
    color: #32805f;
  }

  .markdown-content .callout-info {
    border-left-color: #5da7c7;
    background: #f1f9fc;
  }

  .markdown-content .callout-info .callout-title {
    color: #2e7390;
  }

  .markdown-content .callout-warn,
  .markdown-content .callout-caution {
    border-left-color: #de8f5d;
    background: #fff7f1;
  }

  .markdown-content .callout-warn .callout-title,
  .markdown-content .callout-caution .callout-title {
    color: #b7662d;
  }

  .markdown-content code {
    background: #f4f4f4;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
    font-size: 0.88em;
  }

  .markdown-content pre {
    background: #f8f8f8;
    border-left: 3px solid #e0dbd3;
    padding: 0.85rem 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1em 0;
    position: relative;
  }

  .markdown-content pre code {
    background: none;
    padding: 0;
    font-size: 0.9em;
  }

  .markdown-content .code-copy-btn {
    position: absolute;
    top: 0.65rem;
    right: 0.7rem;
    border: 1px solid #d5dcf1;
    background: rgba(255, 255, 255, 0.94);
    color: #5164b6;
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .markdown-content .code-copy-btn:hover {
    background: #eef2ff;
    color: #4053a8;
  }

  .markdown-content a {
    color: #0066cc;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .markdown-content a:hover {
    text-decoration-style: solid;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 1em 0;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e8e2d9;
    margin: 2rem 0;
  }

  /* Tables */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0;
    font-size: 0.9em;
  }

  .markdown-content th,
  .markdown-content td {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .markdown-content th {
    background: #f8f8f8;
    font-weight: 600;
  }

  .markdown-content tr:nth-child(even) {
    background: #fafafa;
  }

  /* Task lists */
  .markdown-content input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  /* Footnotes */
  .markdown-content .footnotes {
    border-top: 1px solid #e8e2d9;
    margin-top: 2rem;
    padding-top: 1rem;
    font-size: 0.9em;
  }

  .markdown-content .footnotes ol {
    margin: 0;
    padding-left: 1.5rem;
  }

  .markdown-content .footnotes li {
    margin-bottom: 0.5rem;
  }

  /* KaTeX styles */
  .markdown-content .katex {
    font-size: 1.1em;
    white-space: normal;
  }

  .markdown-content .katex-mathml {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .markdown-content .katex-display {
    margin: 1rem 0;
    text-align: center;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.15rem 0;
  }

  .markdown-content .katex-display > .katex {
    display: inline-block;
    max-width: 100%;
  }

  /* Highlight.js styles (GitHub theme) */
  .hljs {
    background: #f6f8fa;
    color: #24292f;
  }

  .hljs-keyword,
  .hljs-selector-tag,
  .hljs-literal,
  .hljs-section,
  .hljs-link {
    color: #d73a49;
  }

  .hljs-built_in,
  .hljs-type {
    color: #6f42c1;
  }

  .hljs-number,
  .hljs-attr,
  .hljs-subst {
    color: #005cc5;
  }

  .hljs-string,
  .hljs-title,
  .hljs-name,
  .hljs-tag .hljs-attr {
    color: #032f62;
  }

  .hljs-symbol,
  .hljs-bullet,
  .hljs-addition {
    color: #22863a;
  }

  .hljs-code,
  .hljs-formula {
    background: #f6f8fa;
  }

  .hljs-comment,
  .hljs-quote {
    color: #6a737d;
  }

  .hljs-meta,
  .hljs-deletion {
    color: #b31d28;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e8e2d9;
    margin: 1.5em 0;
  }

  /* ── Image Gallery (FB-style) ── */
  .image-gallery {
    display: grid;
    gap: 3px;
    background: #000;
    /* max-height so portrait images don't go crazy tall */
  }

  /* 1 image: full width */
  .image-gallery[data-count="1"] {
    grid-template-columns: 1fr;
  }
  .image-gallery[data-count="1"] .gallery-item {
    aspect-ratio: 16 / 9;
  }

  /* 2 images: side by side */
  .image-gallery[data-count="2"] {
    grid-template-columns: 1fr 1fr;
  }
  .image-gallery[data-count="2"] .gallery-item {
    aspect-ratio: 1 / 1;
  }

  /* 3 images: large left + 2 stacked right */
  .image-gallery[data-count="3"] {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .image-gallery[data-count="3"] .gallery-item:first-child {
    grid-row: span 2;
    aspect-ratio: auto;
  }
  .image-gallery[data-count="3"] .gallery-item:not(:first-child) {
    aspect-ratio: 16 / 9;
  }

  /* 4 images: 2x2 */
  .image-gallery[data-count="4"] {
    grid-template-columns: 1fr 1fr;
  }
  .image-gallery[data-count="4"] .gallery-item {
    aspect-ratio: 1 / 1;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border: none;
    padding: 0;
    background: #111;
    display: block;
    width: 100%;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-more {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 1.75rem;
    font-weight: 700;
    pointer-events: none;
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    cursor: pointer;
  }

  .lightbox-img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    position: relative;
    z-index: 1;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  /* ── Engagement bar ── */
  .post-engagement {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.75rem;
    padding-left: 0.1rem;
  }

  .engage-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 46px;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid #dcd8ee;
    background: rgba(255, 255, 255, 0.75);
    color: var(--text-muted, #8a88a8);
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
    font-family: inherit;
  }

  .engage-btn:hover {
    border-color: var(--accent, #5b74c8);
    color: var(--accent, #5b74c8);
    background: var(--accent-bg, #eef1fb);
  }

  .engage-btn.clapped {
    border-color: #f2a7a4;
    color: #ef524d;
    background: rgba(255, 244, 244, 0.95);
  }

  .engage-btn.clapped svg {
    fill: #e44;
    stroke: #e44;
  }

  .engage-btn svg,
  .engage-stat svg {
    width: 21px;
    height: 21px;
    flex-shrink: 0;
  }

  .engage-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 46px;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid #dcd8ee;
    background: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
    color: var(--text-muted, #8a88a8);
  }

  /* ── Comments section ── */
  .post-comments {
    max-width: 680px;
    margin: 0.5rem auto 2rem;
    padding: 1rem 0 0;
    border-top: 1px solid var(--border, #dddaf0);
  }

  /* ── Back nav ── */
  .post-nav {
    margin-bottom: 0.6rem;
  }

  .btn-back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-muted, #8a88a8);
    text-decoration: none;
    transition: color 0.15s;
  }

  .btn-back:hover {
    color: var(--accent, #5b74c8);
  }

  @media (max-width: 640px) {
    article.post {
      padding-top: 0.8rem;
    }

    .post-title-wrapper {
      padding: 1rem 0.95rem 0.7rem;
    }

    .post-text {
      padding: 0.95rem 0.95rem 0.9rem;
    }

    .post-title {
      font-size: 1.32rem;
    }

    .post-engagement {
      gap: 0.55rem;
      flex-wrap: wrap;
    }

    .engage-btn,
    .engage-stat {
      min-height: 42px;
      padding: 0.58rem 0.85rem;
      font-size: 0.9rem;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    article.post {
      padding: 0.75rem 0 1.5rem;
    }

    .post-text {
      padding: 1rem 1rem 0.75rem;
    }
  }
</style>

<script>
  // ── Lightbox ──────────────────────────────────────────────────────────────
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;
  const lightboxOverlay = document.getElementById('lightboxOverlay');
  const lightboxClose = document.getElementById('lightboxClose');

  document.querySelectorAll<HTMLButtonElement>('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      const src = item.dataset.src;
      const alt = item.dataset.alt || '';
      if (lightbox && lightboxImg && src) {
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightbox.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeLightbox() {
    lightbox?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  lightboxOverlay?.addEventListener('click', closeLightbox);
  lightboxClose?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // ── Clap button ──────────────────────────────────────────────────────────
  const clapBtn = document.getElementById('clapBtn') as HTMLButtonElement | null;
  const clapCount = document.getElementById('clapCount');
  if (clapBtn && clapCount) {
    const CLAP_KEY = `clapped:${clapBtn.dataset.entryId}`;
    if (localStorage.getItem(CLAP_KEY)) {
      clapBtn.classList.add('clapped');
    }

    clapBtn.addEventListener('click', async () => {
      const apiBase = clapBtn.dataset.apiBase;
      const entryId = clapBtn.dataset.entryId;
      try {
        const res = await fetch(`${apiBase}/api/entries/${entryId}/clap`, { method: 'POST' });
        if (res.ok) {
          const data = await res.json() as { clap_count: number };
          clapCount.textContent = String(data.clap_count);
          clapBtn.classList.add('clapped');
          localStorage.setItem(CLAP_KEY, '1');
        }
      } catch {}
    });
  }

  // ── View tracking ────────────────────────────────────────────────────────
  (() => {
    const btn = document.getElementById('clapBtn') as HTMLButtonElement | null;
    if (!btn) return;
    const apiBase = btn.dataset.apiBase;
    const entryId = btn.dataset.entryId;
    const VIEW_KEY = `viewed:${entryId}`;
    if (sessionStorage.getItem(VIEW_KEY)) return;
    sessionStorage.setItem(VIEW_KEY, '1');
    fetch(`${apiBase}/api/entries/${entryId}/view`, { method: 'POST' }).then((r) => {
      if (r.ok) {
        const viewEl = document.getElementById('viewCount');
        if (viewEl) viewEl.textContent = String(parseInt(viewEl.textContent || '0') + 1);
      }
    }).catch(() => {});
  })();
</script>
