---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ReaderControls from '../../components/ReaderControls.astro'
import { formatDate } from '@personal-blog/shared'
import 'katex/dist/katex.min.css'
import type { Asset } from '@personal-blog/shared'
import { renderMarkdownToHtml, stripFirstH1 } from '../../lib/markdown'
import { getEntryBySlug, getAssetsByEntryId } from '../../lib/data'
import { applyPageCacheHeaders } from '../../lib/response'


const slug = Astro.params.slug

// SSR: 每次請求時取最新資料
const entry = slug ? await getEntryBySlug(decodeURIComponent(slug)) : null

if (!entry) {
  return Astro.redirect('/articles')
}

const displayTitle = entry.title?.replace(/^#+\s+/, '').trim() || formatDate(entry.created_at)
const cleanedMarkdown = stripFirstH1(entry.content_markdown || '')
const renderedContent = await renderMarkdownToHtml(cleanedMarkdown)

// Fetch assets (cover image, etc.)
const assets = await getAssetsByEntryId(entry.id)
const coverAsset = assets.find((asset) => asset.kind === 'cover')
const imageAssets = assets.filter((asset) => asset.kind === 'image')
const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://personal-blog-api.personal-blog.workers.dev'

// 應用快取策略：10分鐘 CDN 快取 + 1小時過期後仍可用
applyPageCacheHeaders(Astro.response, 'detail')
---

<BaseLayout title={`${displayTitle} | Double River`}>
  <ReaderControls client:load />
  <article class="article">
    <header class="article-header">
      <div class="article-meta">
        <time datetime={entry.created_at}>{formatDate(entry.created_at)}</time>
        {entry.category && (
          <span class="category">{entry.category}</span>
        )}
      </div>
      <h1>{displayTitle}</h1>
      {coverAsset && (
        <img
          class="cover-image"
          src={`${API_BASE}/api/assets/${coverAsset.storage_key}`}
          alt={coverAsset.alt_text || displayTitle}
          width={coverAsset.width}
          height={coverAsset.height}
        />
      )}
    </header>

    <div class="article-content">
      <div class="markdown-content" set:html={renderedContent} />
      {imageAssets.length > 0 && (
        <div class="article-images">
          {imageAssets.map((asset: Asset) => (
            <img
              src={`${API_BASE}/api/assets/${asset.storage_key}`}
              alt={asset.alt_text || ''}
              width={asset.width}
              height={asset.height}
              loading="lazy"
            />
          ))}
        </div>
      )}
    </div>

    <footer class="article-footer">
      <nav class="article-nav">
        <a href="/articles" class="btn-back">← 返回文章</a>
        {entry.category && (
          <a href={`/c/${entry.category}`} class="btn-category">
            查看此分類
          </a>
        )}
      </nav>
    </footer>
  </article>
</BaseLayout>

<script is:inline>
  function initCodeCopy(root = document) {
    root.querySelectorAll('.markdown-content pre').forEach((pre) => {
      if (!(pre instanceof HTMLElement) || pre.dataset.copyBound === '1') return;
      pre.dataset.copyBound = '1';

      const code = pre.querySelector('code');
      if (!(code instanceof HTMLElement)) return;

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'code-copy-btn';
      button.textContent = '複製';

      button.addEventListener('click', async () => {
        const text = code.innerText;
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = '已複製';
          window.setTimeout(() => {
            button.textContent = '複製';
          }, 1400);
        } catch {
          button.textContent = '失敗';
          window.setTimeout(() => {
            button.textContent = '複製';
          }, 1400);
        }
      });

      pre.appendChild(button);
    });
  }

  initCodeCopy();
  document.addEventListener('astro:after-swap', () => initCodeCopy());
</script>

<style is:global>
  article.article {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.2rem 0 1.8rem;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.35rem;
    border-bottom: 1px solid #e6deef;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.86rem;
    color: #8b88a6;
    margin-bottom: 0.8rem;
    text-transform: lowercase;
  }

  .category {
    color: #4b6fc8;
    font-weight: 600;
  }

  .article-header h1 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin-bottom: 0.85rem;
  }

  .excerpt {
    max-width: 56rem;
    font-size: 1.08rem;
    color: #6f6c7f;
    line-height: 1.65;
  }

  .cover-image {
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin-top: 1.5rem;
  }

  .article-images {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .article-images img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .article-content {
    font-size: 1.08rem;
    line-height: 1.9;
    color: #333;
    margin: 1.6rem 0;
  }

  .markdown-content {
    font-size: 1.08rem;
    line-height: 1.9;
    color: #2d2d38;
  }

  .markdown-content > * + * {
    margin-top: 1.15rem;
  }

  .markdown-content p {
    margin-bottom: 0;
  }

  .markdown-content h1,
  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4,
  .markdown-content h5,
  .markdown-content h6 {
    margin-top: 2rem;
    margin-bottom: 0.4rem;
    font-weight: 600;
    line-height: 1.25;
    color: #1d2034;
    position: relative;
  }

  .markdown-content h1 { font-size: 1.8rem; }
  .markdown-content h2 { font-size: 1.55rem; }
  .markdown-content h3 { font-size: 1.3rem; }

  .markdown-content .heading-anchor {
    color: #666;
    text-decoration: none;
    margin-left: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .markdown-content h1:hover .heading-anchor,
  .markdown-content h2:hover .heading-anchor,
  .markdown-content h3:hover .heading-anchor,
  .markdown-content h4:hover .heading-anchor,
  .markdown-content h5:hover .heading-anchor,
  .markdown-content h6:hover .heading-anchor {
    opacity: 1;
  }

  .markdown-content figure.md-figure {
    margin: 1.4rem 0;
  }

  .markdown-content figure.md-figure img {
    margin: 0;
  }

  .markdown-content figcaption.md-figcaption {
    margin-top: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #7a7890;
    text-align: center;
  }

  .markdown-content ul,
  .markdown-content ol {
    margin: 0.85rem 0 0.85rem 0.15rem;
    padding-left: 1.45rem;
  }

  .markdown-content li {
    margin-bottom: 0.5rem;
  }

  .markdown-content li > ul,
  .markdown-content li > ol {
    margin-top: 0.45rem;
    margin-bottom: 0.55rem;
  }

  .markdown-content li > p {
    margin-bottom: 0.5rem;
  }

  .markdown-content code {
    background: #eef1fb;
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
    font-family: 'SFMono-Regular', 'Cascadia Code', 'Courier New', monospace;
    font-size: 0.9em;
  }

  .markdown-content pre {
    background: #f7f8fc;
    border: 1px solid #e0e5f3;
    padding: 1rem 1.1rem;
    border-radius: 12px;
    overflow-x: auto;
    margin: 1.3rem 0;
    position: relative;
  }

  .markdown-content pre code {
    background: none;
    padding: 0;
  }

  .markdown-content .code-copy-btn {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    border: 1px solid #d5dcf1;
    background: rgba(255, 255, 255, 0.92);
    color: #5164b6;
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
    font-size: 0.74rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .markdown-content .code-copy-btn:hover {
    background: #eef2ff;
    color: #4053a8;
  }

  .markdown-content blockquote {
    border-left: 4px solid #aab8ea;
    margin: 1.3rem 0;
    color: #57556b;
    background: #f6f7fe;
    padding: 0.9rem 1.1rem 0.9rem 1.15rem;
    border-radius: 0 12px 12px 0;
    font-style: normal;
  }

  .markdown-content blockquote > :first-child {
    margin-top: 0;
  }

  .markdown-content blockquote > :last-child {
    margin-bottom: 0;
  }

  .markdown-content blockquote ol,
  .markdown-content blockquote ul {
    margin-left: 0.1rem;
  }

  .markdown-content .callout {
    border-left-width: 5px;
    border-left-style: solid;
    padding: 0.95rem 1.1rem 0.95rem 1.15rem;
  }

  .markdown-content .callout-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.55rem;
  }

  .markdown-content .callout-note {
    border-left-color: #7d8fdc;
    background: #f5f7ff;
  }

  .markdown-content .callout-note .callout-title {
    color: #5369c6;
  }

  .markdown-content .callout-tip {
    border-left-color: #5eaf8b;
    background: #f2fbf6;
  }

  .markdown-content .callout-tip .callout-title {
    color: #32805f;
  }

  .markdown-content .callout-info {
    border-left-color: #5da7c7;
    background: #f1f9fc;
  }

  .markdown-content .callout-info .callout-title {
    color: #2e7390;
  }

  .markdown-content .callout-warn,
  .markdown-content .callout-caution {
    border-left-color: #de8f5d;
    background: #fff7f1;
  }

  .markdown-content .callout-warn .callout-title,
  .markdown-content .callout-caution .callout-title {
    color: #b7662d;
  }

  .markdown-content a {
    color: #0066cc;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
  }

  .markdown-content a:hover {
    text-decoration-style: solid;
  }

  .markdown-content img {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 1rem 0;
  }

  .markdown-content hr {
    border: none;
    border-top: 1px solid #e6deef;
    margin: 1.8rem 0;
  }

  /* Tables */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9em;
  }

  .markdown-content th,
  .markdown-content td {
    border: 1px solid #ddd;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .markdown-content th {
    background: #f4f6fd;
    font-weight: 600;
  }

  .markdown-content tr:nth-child(even) {
    background: #fafafa;
  }

  /* Task lists */
  .markdown-content input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  .markdown-content .contains-task-list {
    list-style: none;
    margin-left: 0;
    padding-left: 0;
  }

  .markdown-content details {
    border: 1px solid #dfe2f2;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    background: #fcfcff;
  }

  .markdown-content summary {
    cursor: pointer;
    font-weight: 600;
    color: #303654;
  }

  /* Footnotes */
  .markdown-content .footnotes {
    border-top: 1px solid #e8e2d9;
    margin-top: 2rem;
    padding-top: 1rem;
    font-size: 0.9em;
  }

  .markdown-content .footnotes ol {
    margin: 0;
    padding-left: 1.5rem;
  }

  .markdown-content .footnotes li {
    margin-bottom: 0.5rem;
  }

  /* KaTeX styles */
  .markdown-content .katex {
    font-size: 1.1em;
    white-space: normal;
  }

  .markdown-content .katex-mathml {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .markdown-content .katex-display {
    margin: 1rem 0;
    text-align: center;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.15rem 0;
  }

  .markdown-content .katex-display > .katex {
    display: inline-block;
    max-width: 100%;
  }

  /* Highlight.js styles (GitHub theme) */
  .hljs {
    background: #f6f8fa;
    color: #24292f;
  }

  .hljs-keyword,
  .hljs-selector-tag,
  .hljs-literal,
  .hljs-section,
  .hljs-link {
    color: #d73a49;
  }

  .hljs-built_in,
  .hljs-type {
    color: #6f42c1;
  }

  .hljs-number,
  .hljs-attr,
  .hljs-subst {
    color: #005cc5;
  }

  .hljs-string,
  .hljs-title,
  .hljs-name,
  .hljs-tag .hljs-attr {
    color: #032f62;
  }

  .hljs-symbol,
  .hljs-bullet,
  .hljs-addition {
    color: #22863a;
  }

  .hljs-code,
  .hljs-formula {
    background: #f6f8fa;
  }

  .hljs-comment,
  .hljs-quote {
    color: #6a737d;
  }

  .hljs-meta,
  .hljs-deletion {
    color: #b31d28;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e8e2d9;
  }

  .article-nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-back,
  .btn-category {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .btn-back {
    background: #f0f0f0;
    color: #333;
  }

  .btn-back:hover {
    background: #e0e0e0;
  }

  .btn-category {
    background: #0066cc;
    color: white;
  }

  .btn-category:hover {
    background: #0052a3;
  }

  @media (max-width: 640px) {
    .article-header h1 {
      font-size: 1.5rem;
    }

    .article-nav {
      flex-direction: column;
    }

    .btn-back,
    .btn-category {
      width: 100%;
      text-align: center;
    }
  }
</style>
