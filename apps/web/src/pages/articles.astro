---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getArticles, getPopularTags, getProfile } from '../lib/data'
import { buildEntryCardModels, splitTagSummaryGroups } from '../lib/presenters'
import { applyPageCacheHeaders } from '../lib/response'
import { SERIES_DEFINITIONS } from '../lib/series'

const [articles, popularTags, profile] = await Promise.all([
  getArticles(),
  getPopularTags({ type: 'article', limit: 16 }),
  getProfile(),
])

const articleModels = await buildEntryCardModels(articles, { excerptLength: 150 })
const latestArticles = articleModels.slice(0, 7)
const groupedPopularTags = splitTagSummaryGroups(popularTags)
applyPageCacheHeaders(Astro.response, 'articles')
---

<BaseLayout title="文章 | Double River" description="整理過、值得回頭找的長文與評論。">
  <div class="articles-shell">
    <header class="articles-header">
      <p class="articles-kicker">category index</p>
      <h1>文章</h1>
      <p class="articles-desc">整理過、值得回頭翻找的長文、心得與評論。</p>
      <div class="articles-actions">
        <a href="/search?type=article" class="articles-search-link">搜尋文章</a>
      </div>
    </header>

    <section class="series-grid" aria-label="專題入口">
      {SERIES_DEFINITIONS.map((series) => (
        <a href={`/series/${series.slug}`} class="series-card">
          <span class="series-card-kicker">{series.kicker}</span>
          <h2>{series.title}</h2>
          <p>{series.description}</p>
        </a>
      ))}
    </section>

    <div class="articles-layout">
      <section class="articles-main" aria-label="文章清單">
        {articleModels.length > 0 ? (
          articleModels.map((vm) => (
            <article class="article-index-item">
              <a href={vm.href} class="article-index-link">
                <div class="article-index-meta">
                  <time datetime={vm.rawDate}>{vm.displayDate}</time>
                </div>
                <h2>{vm.displayTitle}</h2>
                <p class="article-index-excerpt">{vm.displayExcerpt}</p>
              </a>

              <div class="article-index-footer">
                <span>留言 {vm.metrics.comment_count}</span>
                <span>拍手 {vm.metrics.clap_count}</span>
                <span>閱讀 {vm.metrics.view_count}</span>
              </div>
            </article>
          ))
        ) : (
          <p class="empty-state">還沒有任何文章</p>
        )}
      </section>

      <aside class="articles-sidebar" aria-label="文章側欄">
        <section class="sidebar-card profile-card">
          <p class="sidebar-eyebrow">about</p>
          <h2>{profile.name}</h2>
          <p>{profile.bio || '把讀過、想過、走過的事整理成可回頭翻找的文字。'}</p>
        </section>

        <section class="sidebar-card">
          <div class="sidebar-title">最新文章</div>
          <ul class="sidebar-list">
            {latestArticles.map((article) => (
              <li>
                <a href={article.href}>{article.displayTitle}</a>
                <time datetime={article.rawDate}>{article.displayDate}</time>
              </li>
            ))}
          </ul>
        </section>

        {popularTags.length > 0 && (
          <section class="sidebar-card">
            <div class="sidebar-title sidebar-title-with-link">
              <span>熱門標籤</span>
              <a href="/tags">全部標籤</a>
            </div>
            <div class="sidebar-tag-groups">
              {groupedPopularTags.structured.length > 0 && (
                <section class="sidebar-tag-section">
                  <p class="sidebar-tag-section-kicker">structured tags</p>
                  {groupedPopularTags.structured.map((group) => (
                    <section class="sidebar-tag-group">
                      <h3>{group.label}</h3>
                      <div class="sidebar-tag-cloud">
                        {group.tags.map((tag) => (
                          <a href={`/tags/${tag.slug}`} class="sidebar-tag">
                            <span>#{tag.normalizedLabel}</span>
                            <span>{tag.entry_count}</span>
                          </a>
                        ))}
                      </div>
                    </section>
                  ))}
                </section>
              )}
              {groupedPopularTags.free.length > 0 && (
                <section class="sidebar-tag-section">
                  <p class="sidebar-tag-section-kicker">free tags</p>
                  {groupedPopularTags.free.map((group) => (
                    <section class="sidebar-tag-group">
                      <h3>{group.label}</h3>
                      <div class="sidebar-tag-cloud">
                        {group.tags.map((tag) => (
                          <a href={`/tags/${tag.slug}`} class="sidebar-tag sidebar-tag-free">
                            <span>#{tag.normalizedLabel}</span>
                            <span>{tag.entry_count}</span>
                          </a>
                        ))}
                      </div>
                    </section>
                  ))}
                </section>
              )}
            </div>
          </section>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .articles-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
  }

  .articles-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #ddd8f1;
  }

  .articles-kicker {
    margin: 0 0 0.45rem;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8f89b2;
  }

  .articles-header h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }

  .articles-desc {
    max-width: 46rem;
    color: #726d89;
    font-size: 1rem;
    line-height: 1.7;
  }

  .articles-actions {
    margin-top: 1rem;
  }

  .articles-search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1rem;
    border: 1px solid #d9d6ef;
    border-radius: 999px;
    color: #5164b6;
    background: rgba(255, 255, 255, 0.85);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .articles-search-link:hover {
    background: #eef2ff;
    border-color: #cbd4f5;
  }

  .articles-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 3rem;
    align-items: start;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin-bottom: 1.6rem;
  }

  .series-card {
    padding: 1rem 1.05rem;
    border: 1px solid #dddaf0;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 10px 28px rgba(94, 95, 150, 0.06);
  }

  .series-card-kicker {
    display: block;
    margin-bottom: 0.45rem;
    color: #8f89b2;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .series-card h2 {
    margin: 0 0 0.45rem;
    font-size: 1.1rem;
  }

  .series-card p {
    margin: 0;
    color: #696481;
    line-height: 1.65;
    font-size: 0.9rem;
  }

  .articles-main {
    min-width: 0;
  }

  .article-index-item {
    padding: 1.2rem 0 1.3rem;
    border-bottom: 1px solid #e2ddee;
  }

  .article-index-link {
    display: block;
  }

  .article-index-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.55rem;
    color: #908ba8;
    font-size: 0.95rem;
  }

  .article-index-item h2 {
    margin: 0 0 0.65rem;
    font-size: 1.15rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: #24253d;
  }

  .article-index-link:hover h2 {
    color: #4b6fc8;
  }

  .article-index-excerpt {
    max-width: 54rem;
    margin: 0;
    color: #66627b;
    font-size: 1rem;
    line-height: 1.8;
  }

  .article-index-footer {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.9rem;
    color: #9a94af;
    font-size: 0.9rem;
  }

  .articles-sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-card {
    padding: 1rem 1.05rem;
    border: 1px solid #dddaf0;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 10px 28px rgba(94, 95, 150, 0.06);
  }

  .sidebar-eyebrow {
    margin: 0 0 0.4rem;
    color: #8f89b2;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
  }

  .profile-card h2 {
    margin: 0 0 0.35rem;
    font-size: 1.25rem;
  }

  .profile-card p {
    margin: 0;
    color: #696481;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .sidebar-title {
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #5e5b79;
    letter-spacing: 0.08em;
  }

  .sidebar-title-with-link {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
  }

  .sidebar-title-with-link a {
    color: #5164b6;
    font-size: 0.8rem;
    letter-spacing: normal;
    font-weight: 600;
  }

  .sidebar-list,
  .sidebar-category-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-list li + li,
  .sidebar-category-list li + li {
    margin-top: 0.7rem;
  }

  .sidebar-list a {
    display: block;
    color: #2b2d43;
    line-height: 1.45;
  }

  .sidebar-list time {
    display: block;
    margin-top: 0.2rem;
    color: #9892ae;
    font-size: 0.82rem;
  }

  .sidebar-category-list a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #4b4a60;
  }

  .sidebar-category-list a:hover,
  .sidebar-list a:hover {
    color: #4b6fc8;
  }

  .sidebar-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .sidebar-tag-groups {
    display: grid;
    gap: 0.95rem;
  }

  .sidebar-tag-section {
    display: grid;
    gap: 0.75rem;
  }

  .sidebar-tag-section-kicker {
    margin: 0;
    color: #8f89b2;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .sidebar-tag-group h3 {
    margin: 0 0 0.55rem;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8f89b2;
  }

  .sidebar-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    border: 1px solid #ddd8f1;
    color: #54506d;
    background: #fff;
    font-size: 0.84rem;
  }

  .sidebar-tag:hover {
    color: #4b6fc8;
    border-color: #cdd6f2;
    background: #f7f9ff;
  }

  .sidebar-tag-free {
    border-style: dashed;
    background: #fffdf9;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 3rem;
  }

  @media (max-width: 900px) {
    .series-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .articles-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .articles-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .articles-shell {
      padding: 1.25rem 1rem;
    }

    .series-grid {
      grid-template-columns: 1fr;
    }

    .article-index-item {
      padding: 1rem 0 1.05rem;
    }

    .article-index-item h2 {
      font-size: 1.5rem;
      line-height: 1.2;
    }

    .article-index-excerpt {
      font-size: 0.95rem;
      line-height: 1.75;
    }
  }
</style>
