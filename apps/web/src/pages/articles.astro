---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getArticles } from '../lib/data'
import { formatDate } from '@personal-blog/shared'
import { extractPlainText } from '../lib/markdown'
import { applyPageCacheHeaders } from '../lib/response'

const categoryLabels: Record<string, string> = {
  journal: '日記',
  reading: '讀書',
  travel: '旅行',
  place: '地點',
}

// SSR: 每次請求時取最新資料
const articles = await getArticles()
const displayArticles = articles.map((article) => ({
  ...article,
  displayTitle: article.title?.trim() || formatDate(article.created_at),
  displayExcerpt: extractPlainText(article.content_markdown || '', 150),
  categoryLabel: categoryLabels[article.category] || article.category,
}))

// 應用快取策略：5分鐘 CDN 快取 + 30分鐘過期後仍可用
applyPageCacheHeaders(Astro.response, 'articles')
---

<BaseLayout title="文章 | Double River" description="整理過、值得回頭找的長文與評論。">
  <div class="articles-container">
    <header class="articles-header">
      <h1>文章</h1>
      <p class="articles-desc">整理過的評論、旅記、讀書心得、長篇日記</p>
    </header>

    <ol class="articles-list">
      {
        displayArticles.length > 0 ? (
          displayArticles.map((article) => (
            <li class="article-item">
              <a class="article-link" href={`/article/${encodeURIComponent(article.slug || '')}`}>
                <h2 class="article-title">{article.displayTitle}</h2>
                {article.displayExcerpt && (
                  <p class="article-excerpt">{article.displayExcerpt}</p>
                )}
              </a>
              <div class="article-meta">
                <span class="article-category">{article.categoryLabel}</span>
                <time datetime={article.created_at}>{formatDate(article.created_at)}</time>
              </div>
            </li>
          ))
        ) : (
          <p class="empty-state">還沒有任何文章</p>
        )
      }
    </ol>
  </div>
</BaseLayout>

<style>
  .articles-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .articles-header {
    margin-bottom: 2.5rem;
  }

  .articles-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .articles-desc {
    color: #888;
    font-size: 0.95rem;
  }

  .articles-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid #e8e2d9;
  }

  .article-item:first-child {
    padding-top: 0;
  }

  .article-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .article-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.5;
    margin: 0 0 0.5rem;
    color: #2c5d8f;
    transition: color 0.15s;
  }

  .article-link:hover .article-title {
    color: #1a3d5c;
    text-decoration: underline;
  }

  .article-excerpt {
    margin: 0;
    font-size: 0.92rem;
    color: #555;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.6rem;
    font-size: 0.85rem;
    color: #999;
  }

  .article-category {
    color: #666;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 3rem;
  }

  @media (max-width: 640px) {
    .articles-container {
      padding: 1.25rem 1rem;
    }

    .articles-header h1 {
      font-size: 1.3rem;
    }

    .article-title {
      font-size: 1.05rem;
    }
  }
</style>
