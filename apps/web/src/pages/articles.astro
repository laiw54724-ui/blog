---
import BaseLayout from '../layouts/BaseLayout.astro'
import EntryCard from '../components/EntryCard.astro'
import { getArticles } from '../lib/data'
import { buildEntryCardModels } from '../lib/presenters'
import { applyPageCacheHeaders } from '../lib/response'

const articles = await getArticles()
const articleModels = await buildEntryCardModels(articles, { excerptLength: 150 })

applyPageCacheHeaders(Astro.response, 'articles')
---

<BaseLayout title="文章 | Double River" description="整理過、值得回頭找的長文與評論。">
  <div class="articles-container">
    <header class="articles-header">
      <h1>文章</h1>
      <p class="articles-desc">整理過的評論、旅記、讀書心得、長篇日記</p>
    </header>

    <div class="articles-list">
      {
        articleModels.length > 0 ? (
          articleModels.map((vm) => (
            <EntryCard
              href={vm.href}
              title={vm.displayTitle}
              excerpt={vm.displayExcerpt}
              date={vm.displayDate}
              categoryLabel={vm.categoryLabel}
              coverUrl={vm.coverUrl}
              coverAlt={vm.coverAlt}
              stats={vm.metrics}
              variant="list"
            />
          ))
        ) : (
          <p class="empty-state">還沒有任何文章</p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .articles-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .articles-header {
    margin-bottom: 2.5rem;
  }

  .articles-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .articles-desc {
    color: #888;
    font-size: 0.95rem;
  }

  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty-state {
    text-align: center;
    color: #999;
    padding: 3rem;
  }

  @media (max-width: 640px) {
    .articles-container {
      padding: 1.25rem 1rem;
    }

    .articles-header h1 {
      font-size: 1.3rem;
    }
  }
</style>
