---
import type { Comment } from '@personal-blog/shared'
import { renderCommentMarkdownSafe } from '../lib/markdown'

interface Props {
  entryId: string
  initialComments: Comment[]
  apiBase: string
}

const {
  entryId,
  initialComments,
  apiBase,
} = Astro.props as Props
---
<section class="comment-board" data-entry-id={entryId} data-api-base={apiBase}>
  <div class="comment-board-header">
    <h2>留言板</h2>
    <span class="comment-count">{initialComments.length}</span>
  </div>

  <form class="comment-form">
    <input
      class="comment-input"
      type="text"
      name="author_name"
      maxlength="40"
      placeholder="你的名字"
    />

    <input type="hidden" name="form_started_at" value={Date.now()} />

    <div class="honeypot" aria-hidden="true">
      <label>
        Website
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <textarea
      class="comment-textarea"
      name="body_markdown"
      rows="4"
      maxlength="2000"
      placeholder="寫點什麼吧"
      required
    ></textarea>

    <div class="comment-form-actions">
      <button type="submit" class="comment-submit">送出留言</button>
      <span class="comment-status" aria-live="polite"></span>
    </div>
  </form>

  <div class="comment-list">
    {initialComments.length > 0 ? (
      initialComments.map((comment) => (
        <article class="comment-item" data-comment-id={comment.id}>
          <header class="comment-meta">
            <strong>{comment.author_name || '匿名'}</strong>
            <time datetime={comment.created_at}>
              {new Date(comment.created_at).toLocaleString('zh-TW')}
            </time>
          </header>
          <div class="comment-body" set:html={renderCommentMarkdownSafe(comment.body_markdown)} />
        </article>
      ))
    ) : (
      <p class="empty-comments">還沒有留言，來當第一個敲門的人。</p>
    )}
  </div>
</section>
<style>
  .comment-board {
    margin-top: 2rem;
  }

  .comment-board-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .comment-board-header h2 {
    font-size: 1.15rem;
    margin: 0;
  }

  .comment-count {
    color: #888;
    font-size: 0.9rem;
  }

  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid #ece7df;
    border-radius: 10px;
    background: #fcfbf9;
  }

  .comment-input,
  .comment-textarea {
    width: 100%;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 0.8rem 0.9rem;
    font: inherit;
    background: white;
  }

  .comment-textarea {
    resize: vertical;
    min-height: 110px;
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .comment-form-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .comment-submit {
    border: none;
    border-radius: 8px;
    background: #2f68c8;
    color: white;
    padding: 0.7rem 1rem;
    font: inherit;
    cursor: pointer;
  }

  .comment-status {
    font-size: 0.9rem;
    color: #777;
  }

  .comment-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .comment-item {
    padding: 1rem 0;
    border-top: 1px solid #eee7dc;
  }

  .comment-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .comment-meta time {
    color: #888;
    font-size: 0.85rem;
  }

  .comment-item p {
    margin: 0;
    color: #333;
    line-height: 1.8;
    white-space: pre-wrap;
  }

  .empty-comments {
    color: #777;
    line-height: 1.75;
    margin: 0;
  }
</style>
<script>
// @ts-nocheck
        /**
    * @param {string} input
    * @returns {string}
    */
    function renderCommentMarkdownSafe(input) {
    const source = (input || '').replace(/\r\n?/g, '\n')
    if (!source) return ''

    let html = escapeHtml(source)

    html = html.replace(/`([^`]+)`/g, '<code>$1</code>')
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>')
    html = html.replace(/\n/g, '<br>')

    return html
    }

  /**
    * @param {string} text
    * @returns {string}
    */
    function escapeHtml(text) {
    return String(text).replace(/[&<>"']/g, (match) => {
        switch (match) {
        case '&':
            return '&amp;'
        case '<':
            return '&lt;'
        case '>':
            return '&gt;'
        case '"':
            return '&quot;'
        case "'":
            return '&#039;'
        default:
            return match
        }
    })
    }

  document.querySelectorAll('.comment-board').forEach((rootEl) => {
    if (!(rootEl instanceof HTMLElement)) return

    const root = rootEl

    if (root.dataset.bound === '1') return
    root.dataset.bound = '1'

    const entryId = root.dataset.entryId
    const apiBase = root.dataset.apiBase

    const formEl = root.querySelector('.comment-form')
    const listEl = root.querySelector('.comment-list')
    const statusEl = root.querySelector('.comment-status')
    const countEl = root.querySelector('.comment-count')
    const textareaEl = root.querySelector('textarea[name="body_markdown"]')
    const authorInputEl = root.querySelector('input[name="author_name"]')
    const websiteInputEl = root.querySelector('input[name="website"]')
    const startedAtInputEl = root.querySelector('input[name="form_started_at"]')

    if (!(formEl instanceof HTMLFormElement)) return
    if (!(listEl instanceof HTMLElement)) return
    if (!(statusEl instanceof HTMLElement)) return
    if (!(textareaEl instanceof HTMLTextAreaElement)) return
    if (!(startedAtInputEl instanceof HTMLInputElement)) return

    const form = formEl
    const list = listEl
    const textarea = textareaEl
    const startedAtInput = startedAtInputEl
    const count = countEl instanceof HTMLElement ? countEl : null
    const authorInput = authorInputEl instanceof HTMLInputElement ? authorInputEl : null
    const websiteInput = websiteInputEl instanceof HTMLInputElement ? websiteInputEl : null

    const updateCount = () => {
      const nextCount = list.querySelectorAll('.comment-item').length
      if (count) count.textContent = String(nextCount)

      const metric = document.querySelector('[data-metric="comments"]')
      if (metric instanceof HTMLElement) {
        metric.textContent = String(nextCount)
      }
    }

    const removeEmptyState = () => {
      const empty = list.querySelector('.empty-comments')
      if (empty instanceof HTMLElement) {
        empty.remove()
      }
    }

    /**
    * @param {{ id: string, author_name: string, body_markdown: string, created_at: string }} comment
    * @returns {void}
    */
    function prependComment(comment) {
    removeEmptyState()

    const article = document.createElement('article')
    article.className = 'comment-item'
    article.dataset.commentId = comment.id
    article.innerHTML = `
        <header class="comment-meta">
        <strong>${escapeHtml(comment.author_name || '匿名')}</strong>
        <time datetime="${comment.created_at}">${new Date(comment.created_at).toLocaleString('zh-TW')}</time>
        </header>
        <p></p>
    `

    const bodyEl = article.querySelector('p')
    if (bodyEl instanceof HTMLParagraphElement) {
        bodyEl.innerHTML = renderCommentMarkdownSafe(comment.body_markdown)
    }

    list.prepend(article)
    updateCount()
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      statusEl.textContent = '送出中…'

      const bodyMarkdown = textarea.value.trim()
      const lower = bodyMarkdown.toLowerCase()

      const suspiciousWords = [
        'viagra',
        'casino',
        'loan',
        '賭場',
        '借貸',
        '發票代開',
        '加賴',
        '加line',
      ]

      if (suspiciousWords.some((word) => lower.includes(word))) {
        statusEl.textContent = '內容看起來像廣告，請修改後再送出'
        return
      }

      const payload = {
        author_name: authorInput ? authorInput.value.trim() || '匿名' : '匿名',
        body_markdown: bodyMarkdown,
        website: websiteInput ? websiteInput.value.trim() || '' : '',
        form_started_at: Number(startedAtInput.value || Date.now()),
      }

      if (!payload.body_markdown) {
        statusEl.textContent = '請先寫點內容'
        return
      }

      try {
        const res = await fetch(`${apiBase}/api/entries/${entryId}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })

        const json = /** @type {{ data?: { id: string, author_name: string, body_markdown: string, created_at: string }, error?: string }} */ (await res.json())

        if (!res.ok) {
          statusEl.textContent = json.error || '留言失敗'
          return
        }

        if (json.data) {
          prependComment(json.data)
          form.reset()
          startedAtInput.value = String(Date.now())

          statusEl.textContent = '留言已送出'
          window.setTimeout(() => {
            statusEl.textContent = ''
          }, 1800)
        }
      } catch {
        statusEl.textContent = '留言失敗，請稍後再試'
      }
    })
  })
</script>