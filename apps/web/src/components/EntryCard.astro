---
interface EntryCardStats {
  comment_count: number
  clap_count: number
  view_count: number
}

interface Props {
  href: string
  title: string
  excerpt?: string
  date?: string
  categoryLabel?: string
  typeLabel?: string
  coverUrl?: string
  coverAlt?: string
  stats?: EntryCardStats
  variant?: 'compact' | 'list'
  showTypeBadge?: boolean
}

const {
  href,
  title,
  excerpt = '',
  date = '',
  categoryLabel = '',
  typeLabel = '',
  coverUrl = '',
  coverAlt = '',
  stats,
  variant = 'list',
  showTypeBadge = false,
} = Astro.props as Props

const hasCover = Boolean(coverUrl)
const hasStats = Boolean(stats)
const hasMeta = Boolean(showTypeBadge || categoryLabel || date)
---

<a
  href={href}
  class={`entry-card entry-card-${variant} ${hasCover ? 'has-cover' : 'no-cover'}`}
>
  {hasCover && (
    <img
      class="entry-card-cover"
      src={coverUrl}
      alt={coverAlt || title}
      loading="lazy"
      width="120"
      height="120"
      decoding="async"
    />
  )}

  <div class="entry-card-main">
    {hasMeta && (
      <div class="entry-card-meta">
        {showTypeBadge && typeLabel && (
          <span class="entry-card-type">{typeLabel}</span>
        )}
        {categoryLabel && <span class="entry-card-category">{categoryLabel}</span>}
        {date && <time datetime={date}>{date}</time>}
      </div>
    )}

    <h3 class="entry-card-title">{title}</h3>

    {excerpt && excerpt !== title && (
      <p class="entry-card-excerpt">{excerpt}</p>
    )}

    {hasStats && (
      <div class="entry-card-stats" aria-label="互動統計">
        <span class="stat-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          {stats!.comment_count}
        </span>
        <span class="stat-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          {stats!.clap_count}
        </span>
        <span class="stat-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          {stats!.view_count}
        </span>
      </div>
    )}
  </div>
</a>

<style>
  .entry-card {
    display: grid;
    gap: 0.95rem;
    padding: 0.95rem;
    border: 1px solid #ece7df;
    border-radius: 14px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .entry-card:hover {
    transform: translateY(-1px);
    border-color: #ddd5ca;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
  }

  .entry-card.no-cover {
    grid-template-columns: 1fr;
  }

  .entry-card-compact.has-cover {
    grid-template-columns: 88px 1fr;
  }

  .entry-card-list.has-cover {
    grid-template-columns: 120px 1fr;
  }

  .entry-card-cover {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 12px;
    background: #f7f7fb;
  }

  .entry-card-main {
    min-width: 0;
  }

  .entry-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 0.45rem;
    font-size: 0.82rem;
    color: #8a8a8a;
  }

  .entry-card-type {
    display: inline-block;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    background: #f2f4f8;
    color: #5b6474;
  }

  .entry-card-category {
    color: #666;
  }

  .entry-card-title {
    margin: 0 0 0.35rem;
    line-height: 1.45;
    color: #244f77;
    font-weight: 600;
    transition: color 0.15s ease;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .entry-card:hover .entry-card-title {
    color: #1a3d5c;
    text-decoration: underline;
  }

  .entry-card-compact .entry-card-title {
    font-size: 1rem;
    -webkit-line-clamp: 2;
  }

  .entry-card-list .entry-card-title {
    font-size: 1.15rem;
    -webkit-line-clamp: 2;
  }

  .entry-card-excerpt {
    margin: 0;
    color: #5f5f5f;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .entry-card-compact .entry-card-excerpt {
    font-size: 0.88rem;
    -webkit-line-clamp: 2;
  }

  .entry-card-list .entry-card-excerpt {
    font-size: 0.92rem;
    -webkit-line-clamp: 3;
  }

  .entry-card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.65rem;
    font-size: 0.82rem;
    color: #777;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .stat-item svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .entry-card {
      gap: 0.8rem;
      padding: 0.85rem;
    }

    .entry-card-compact.has-cover {
      grid-template-columns: 76px 1fr;
    }

    .entry-card-list.has-cover {
      grid-template-columns: 88px 1fr;
    }

    .entry-card-compact .entry-card-title {
      font-size: 0.96rem;
    }

    .entry-card-list .entry-card-title {
      font-size: 1rem;
    }

    .entry-card-list .entry-card-excerpt {
      font-size: 0.88rem;
      -webkit-line-clamp: 2;
    }
  }
</style>
